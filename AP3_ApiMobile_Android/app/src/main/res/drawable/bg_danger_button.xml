<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#FFF1F2" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="@color/app_danger_dark" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/app_glass_strong" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="@color/app_danger" />
        </shape>
    </item>
</selector>
